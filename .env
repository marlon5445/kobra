#--------------------------------------------------------------------
# KOBRA POS/ERP - CONFIGURACIÓN DEL ENTORNO
#--------------------------------------------------------------------

# Entorno: development (desarrollo, muestra errores) o production (producción)
CI_ENVIRONMENT = development

# URL Base del proyecto (WampServer local)
app.baseURL = 'http://localhost/kobra/'

#--------------------------------------------------------------------
# CONFIGURACIÓN DE LA BASE DE DATOS
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = kobra
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
